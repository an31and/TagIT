+Visitor counts are stored as lightweight per-day aggregate documents in the
+`metrics` collection (one doc per day, atomic $inc) so the collection never
+grows with traffic and a simple 7-day trend is cheap to read.
+"""
+from __future__ import annotations
+
+from datetime import datetime, timedelta, timezone
+
+from fastapi import APIRouter, Depends, HTTPException, Request
+
+from auth import get_current_user
+from db import get_db
+
+router = APIRouter(prefix="/api", tags=["admin"])
+
+
+def _today() -> str:
+    return datetime.now(timezone.utc).strftime("%Y-%m-%d")
+
+
+async def require_admin(request: Request) -> dict:
+    """Allow only users whose role is 'admin'. Enforced server-side regardless
+    of anything the client claims."""
+    user = await get_current_user(request, get_db())
+    if user.get("role") != "admin":
+        raise HTTPException(status_code=403, detail="Admin access required")
+    return user
+
+
+@router.post("/metrics/visit")
+async def record_visit() -> dict:
+    """Public beacon the landing page pings once on load. Best-effort; never
+    blocks or errors the client experience."""
+    db = get_db()
+    day = _today()
+    try:
+        await db.metrics.update_one(
+            {"_id": f"visit:{day}"},
+            {"$inc": {"count": 1}, "$setOnInsert": {"type": "visit", "day": day}},
+            upsert=True,
+        )
+    except Exception:
+        # Analytics must never break the page.
+        return {"ok": False}
+    return {"ok": True}
+
+
+@router.get("/admin/stats")
+async def admin_stats(_: dict = Depends(require_admin)) -> dict:
+    db = get_db()
+
+    scans_total = await db.scans.count_documents({})
+    items_found = await db.tags.count_documents({"status": "found"})
+    lost_active = await db.tags.count_documents({"status": "lost"})
+    total_tags = await db.tags.count_documents({})
+    total_users = await db.users.count_documents({})
+    messages_total = await db.messages.count_documents({})
+
+    # Visitors: sum of all daily visit counters.
+    visitors_total = 0
+    visit_cursor = db.metrics.find({"type": "visit"}, {"count": 1})
+    async for doc in visit_cursor:
+        visitors_total += int(doc.get("count", 0))
+
+    # Last 7 days trend (oldest → newest), zero-filled for missing days.
+    days = [
+        (datetime.now(timezone.utc) - timedelta(days=i)).strftime("%Y-%m-%d")
+        for i in range(6, -1, -1)
+    ]
+    day_docs = {}
+    async for doc in db.metrics.find({"_id": {"$in": [f"visit:{d}" for d in days]}}):
+        day_docs[doc["day"]] = int(doc.get("count", 0))
+    visits_last_7_days = [{"day": d, "count": day_docs.get(d, 0)} for d in days]
+
+    return {
+        "visitors_total": visitors_total,
+        "scans_total": scans_total,
+        "items_found": items_found,
+        "lost_active": lost_active,
+        "total_tags": total_tags,
+        "total_users": total_users,
+        "messages_total": messages_total,
+        "visits_last_7_days": visits_last_7_days,
+    }
