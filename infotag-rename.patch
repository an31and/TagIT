diff --git a/.github/workflows/backend-image.yml b/.github/workflows/backend-image.yml
new file mode 100644
index 0000000..b478852
--- /dev/null
+++ b/.github/workflows/backend-image.yml
@@ -0,0 +1,37 @@
+name: Build backend image
+
+# Builds the FastAPI backend and publishes it to GitHub Container Registry
+# (ghcr.io) — free for public images. Azure Container Apps then pulls this
+# public image directly, so no paid Azure Container Registry is needed.
+
+on:
+  push:
+    branches: [main]
+    paths:
+      - "backend/**"
+      - ".github/workflows/backend-image.yml"
+  workflow_dispatch: {}
+
+jobs:
+  build-and-push:
+    runs-on: ubuntu-latest
+    permissions:
+      contents: read
+      packages: write
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Log in to GitHub Container Registry
+        uses: docker/login-action@v3
+        with:
+          registry: ghcr.io
+          username: ${{ github.actor }}
+          password: ${{ secrets.GITHUB_TOKEN }}
+
+      - name: Build and push
+        uses: docker/build-push-action@v6
+        with:
+          context: ./backend
+          push: true
+          tags: ghcr.io/${{ github.repository_owner }}/infotag-api:latest
