diff --git a/frontend/src/pages/Admin.jsx b/frontend/src/pages/Admin.jsx
new file mode 100644
index 0000000..2c60a3f
--- /dev/null
+++ b/frontend/src/pages/Admin.jsx
@@ -0,0 +1,155 @@
+import { useEffect, useState } from "react";
+import { Navigate } from "react-router-dom";
+import {
+    Users,
+    ScanLine,
+    PackageCheck,
+    Tag as TagIcon,
+    Inbox,
+    Search,
+} from "lucide-react";
+
+import api, { formatApiError } from "../lib/api";
+import { useAuth } from "../lib/auth";
+
+export default function AdminPage() {
+    const { user } = useAuth();
+    const [stats, setStats] = useState(null);
+    const [error, setError] = useState("");
+    const [loading, setLoading] = useState(true);
+
+    useEffect(() => {
+        let cancelled = false;
+        (async () => {
+            try {
+                const { data } = await api.get("/admin/stats");
+                if (!cancelled) setStats(data);
+            } catch (err) {
+                if (!cancelled) setError(formatApiError(err));
+            } finally {
+                if (!cancelled) setLoading(false);
+            }
+        })();
+        return () => {
+            cancelled = true;
+        };
+    }, []);
+
+    // Client-side guard. The backend enforces admin independently.
+    if (user && user.role !== "admin") return <Navigate to="/dashboard" replace />;
+
+    return (
+        <div className="mx-auto max-w-5xl px-4 sm:px-6 py-8" data-testid="admin-page">
+            <div className="mb-6">
+                <h1 className="font-display font-black text-2xl tracking-tight">Admin overview</h1>
+                <p className="text-sm text-muted-foreground mt-1">
+                    Private dashboard · visible only to you.
+                </p>
+            </div>
+
+            {loading && (
+                <div className="text-muted-foreground animate-pulse-soft">Loading stats…</div>
+            )}
+
+            {!loading && error && (
+                <div className="surface p-6 border-destructive/40 text-sm" data-testid="admin-error">
+                    Couldn’t load stats: {error}
+                </div>
+            )}
+
+            {!loading && stats && (
+                <>
+                    {/* Headline metrics */}
+                    <div className="grid gap-4 sm:grid-cols-3">
+                        <StatCard
+                            icon={<Users className="h-5 w-5" />}
+                            label="Visitors"
+                            value={stats.visitors_total}
+                            hint="Landing-page visits"
+                            testid="stat-visitors"
+                        />
+                        <StatCard
+                            icon={<PackageCheck className="h-5 w-5" />}
+                            label="Items found"
+                            value={stats.items_found}
+                            hint="Tags marked found"
+                            accent
+                            testid="stat-found"
+                        />
+                        <StatCard
+                            icon={<ScanLine className="h-5 w-5" />}
+                            label="Scans"
+                            value={stats.scans_total}
+                            hint="QR finder views"
+                            testid="stat-scans"
+                        />
+                    </div>
+
+                    {/* Supporting numbers */}
+                    <div className="grid gap-4 sm:grid-cols-4 mt-4">
+                        <MiniStat icon={<TagIcon className="h-4 w-4" />} label="Total tags" value={stats.total_tags} />
+                        <MiniStat icon={<Search className="h-4 w-4" />} label="Currently lost" value={stats.lost_active} />
+                        <MiniStat icon={<Users className="h-4 w-4" />} label="Registered users" value={stats.total_users} />
+                        <MiniStat icon={<Inbox className="h-4 w-4" />} label="Messages" value={stats.messages_total} />
+                    </div>
+
+                    {/* 7-day visits trend */}
+                    <div className="surface p-6 mt-6">
+                        <div className="font-display font-bold mb-4">Visitors · last 7 days</div>
+                        <SevenDayBars data={stats.visits_last_7_days} />
+                    </div>
+                </>
+            )}
+        </div>
+    );
+}
+
+function StatCard({ icon, label, value, hint, accent, testid }) {
+    return (
+        <div className={`surface p-6 ${accent ? "border-accent/40" : ""}`} data-testid={testid}>
+            <div
+                className={`inline-flex items-center justify-center w-10 h-10 rounded-lg mb-3 ${
+                    accent ? "bg-accent/10 text-accent" : "bg-primary/10 text-primary"
+                }`}
+            >
+                {icon}
+            </div>
+            <div className="font-display font-black text-3xl leading-none">{value ?? 0}</div>
+            <div className="font-medium mt-1">{label}</div>
+            <div className="text-xs text-muted-foreground mt-0.5">{hint}</div>
+        </div>
+    );
+}
+
+function MiniStat({ icon, label, value }) {
+    return (
+        <div className="surface p-4 flex items-center gap-3">
+            <div className="text-muted-foreground">{icon}</div>
+            <div>
+                <div className="font-display font-bold text-lg leading-none">{value ?? 0}</div>
+                <div className="text-xs text-muted-foreground mt-0.5">{label}</div>
+            </div>
+        </div>
+    );
+}
+
+function SevenDayBars({ data }) {
+    const max = Math.max(1, ...data.map((d) => d.count));
+    return (
+        <div className="flex items-end gap-2 h-32" data-testid="admin-7day">
+            {data.map((d) => (
+                <div key={d.day} className="flex-1 flex flex-col items-center gap-2">
+                    <div className="w-full flex items-end justify-center h-full">
+                        <div
+                            className="w-full max-w-[36px] rounded-t bg-accent/70"
+                            style={{ height: `${Math.round((d.count / max) * 100)}%`, minHeight: d.count > 0 ? 4 : 2 }}
+                            title={`${d.count} visits`}
+                        />
+                    </div>
+                    <div className="text-[10px] text-muted-foreground">{d.day.slice(5)}</div>
+                    <div className="text-xs font-medium -mt-1">{d.count}</div>
+                </div>
+            ))}
+        </div>
+    );
+}
